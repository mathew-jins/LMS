@{
    ViewData["Title"] = "Manage Leave Types";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold">Leave Types</h2>
    <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#leaveTypeModal" onclick="clearLeaveTypeForm()">
        <i class="bi bi-plus-lg"></i> Add Leave Type
    </button>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Leave Type</th>
                        <th>Description</th>
                        <th>Max Days/Year</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody id="leaveTypeTableBody">
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="leaveTypeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Leave Type Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="leaveTypeForm">
                    <input type="hidden" id="leaveTypeId" />
                    <div class="mb-3">
                        <label>Type Name</label>
                        <input type="text" class="form-control" id="leaveTypeName" required>
                    </div>
                    <div class="mb-3">
                        <label>Description</label>
                        <input type="text" class="form-control" id="leaveTypeDesc">
                    </div>
                    <div class="mb-3">
                        <label>Max Days Per Year</label>
                        <input type="number" class="form-control" id="maxDays" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveLeaveType()">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadLeaveTypes();
        });

        function loadLeaveTypes() {
            apiCall('/LeaveTypes', 'GET', null, function(data) {
                let html = '';
                data.forEach(t => {
                    html += `
                        <tr>
                            <td class="ps-4 fw-bold text-dark">${t.leaveTypeName}</td>
                            <td class="text-muted">${t.description}</td>
                            <td><span class="badge bg-info text-dark">${t.maxDaysPerYear} Days</span></td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-primary me-2" onclick="editLeaveType(${t.leaveTypeId}, '${t.leaveTypeName}', '${t.description}', ${t.maxDaysPerYear})"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteLeaveType(${t.leaveTypeId})"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    `;
                });
                $('#leaveTypeTableBody').html(html);
            });
        }

        function clearLeaveTypeForm() {
            $('#leaveTypeId').val('');
            $('#leaveTypeName').val('');
            $('#leaveTypeDesc').val('');
            $('#maxDays').val('');
        }

        function editLeaveType(id, name, desc, maxDays) {
            $('#leaveTypeId').val(id);
            $('#leaveTypeName').val(name);
            $('#leaveTypeDesc').val(desc);
            $('#maxDays').val(maxDays);
            new bootstrap.Modal(document.getElementById('leaveTypeModal')).show();
        }

        function saveLeaveType() {
            const id = $('#leaveTypeId').val();
            const data = {
                leaveTypeName: $('#leaveTypeName').val(),
                description: $('#leaveTypeDesc').val(),
                maxDaysPerYear: parseInt($('#maxDays').val())
            };
            
            if(!id) {
                apiCall('/LeaveTypes', 'POST', data, function() {
                    $('#leaveTypeModal').modal('hide');
                    loadLeaveTypes();
                });
            } else {
                apiCall('/LeaveTypes/' + id, 'PUT', data, function() {
                    $('#leaveTypeModal').modal('hide');
                    loadLeaveTypes();
                });
            }
        }

        function deleteLeaveType(id) {
            if(confirm('Delete this leave type? Note that associated records may cause errors if not handled backend.')) {
                apiCall('/LeaveTypes/' + id, 'DELETE', null, function() {
                    loadLeaveTypes();
                });
            }
        }
    </script>
}
