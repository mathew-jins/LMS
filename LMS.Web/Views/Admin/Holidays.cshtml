@{
    ViewData["Title"] = "Manage Holidays";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold">Company Holidays</h2>
    <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#holidayModal" onclick="clearHolidayForm()">
        <i class="bi bi-calendar-plus"></i> Add Holiday
    </button>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Holiday Name</th>
                        <th>Date</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody id="holidayTableBody">
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="holidayModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Holiday Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="holidayForm">
                    <input type="hidden" id="holidayId" />
                    <div class="mb-3">
                        <label>Holiday Name</label>
                        <input type="text" class="form-control" id="holidayName" required>
                    </div>
                    <div class="mb-3">
                        <label>Date</label>
                        <input type="date" class="form-control" id="holidayDate" required>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveHoliday()">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadHolidays();
        });

        function loadHolidays() {
            apiCall('/Holidays', 'GET', null, function(data) {
                // Sort holidays by date ascending
                data.sort((a,b) => new Date(a.holidayDate) - new Date(b.holidayDate));
                let html = '';
                data.forEach(h => {
                    const dateObj = new Date(h.holidayDate);
                    const formattedDate = dateObj.toLocaleDateString(undefined, { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
                    html += `
                        <tr>
                            <td class="ps-4 fw-bold text-dark">${h.holidayName}</td>
                            <td><span class="badge bg-light text-dark border"><i class="bi bi-calendar-event me-2"></i>${formattedDate}</span></td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-primary me-2" onclick="editHoliday(${h.holidayId}, '${h.holidayName}', '${h.holidayDate.split('T')[0]}')"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteHoliday(${h.holidayId})"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    `;
                });
                $('#holidayTableBody').html(html);
            });
        }

        function clearHolidayForm() {
            $('#holidayId').val('');
            $('#holidayName').val('');
            $('#holidayDate').val('');
        }

        function editHoliday(id, name, date) {
            $('#holidayId').val(id);
            $('#holidayName').val(name);
            $('#holidayDate').val(date);
            new bootstrap.Modal(document.getElementById('holidayModal')).show();
        }

        function saveHoliday() {
            const id = $('#holidayId').val();
            const data = {
                holidayName: $('#holidayName').val(),
                holidayDate: $('#holidayDate').val()
            };
            
            if(!id) {
                apiCall('/Holidays', 'POST', data, function() {
                    $('#holidayModal').modal('hide');
                    loadHolidays();
                });
            } else {
                apiCall('/Holidays/' + id, 'PUT', data, function() {
                    $('#holidayModal').modal('hide');
                    loadHolidays();
                });
            }
        }

        function deleteHoliday(id) {
            if(confirm('Delete this holiday?')) {
                apiCall('/Holidays/' + id, 'DELETE', null, function() {
                    loadHolidays();
                });
            }
        }
    </script>
}
