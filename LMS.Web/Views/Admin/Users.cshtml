@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-primary fw-bold">Manage Users</h2>
    <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#userModal" onclick="clearForm()">
        <i class="bi bi-person-plus"></i> Add New User
    </button>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody id="userTableBody">
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="userModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">User Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="userForm">
                    <input type="hidden" id="userId" />
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>First Name</label>
                            <input type="text" class="form-control" id="firstName" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label>Last Name</label>
                            <input type="text" class="form-control" id="lastName" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label>Email</label>
                        <input type="email" class="form-control" id="userEmail" required>
                    </div>
                    <div class="mb-3" id="passwordGroup">
                        <label>Password</label>
                        <input type="password" class="form-control" id="userPassword">
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label>Role</label>
                            <select class="form-select" id="userRole">
                                <option value="1">User</option>
                                <option value="0">Admin</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3 d-flex align-items-end pb-2" id="activeGroup" style="display:none !important;">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="isActive" checked>
                                <label class="form-check-label" for="isActive">Is Active</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveUser()">Save User</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            loadUsers();
        });

        function loadUsers() {
            apiCall('/Users', 'GET', null, function(data) {
                let html = '';
                data.forEach(u => {
                    const roleLabel = (u.role === 0 || u.role === 'Admin') ? '<span class="badge bg-danger">Admin</span>' : '<span class="badge bg-secondary">User</span>';
                    const activeLabel = u.isActive ? '<span class="badge bg-success">Active</span>' : '<span class="badge bg-dark">Inactive</span>';
                    html += `
                        <tr>
                            <td class="ps-4 fw-bold">${u.firstName} ${u.lastName}</td>
                            <td>${u.email}</td>
                            <td>${roleLabel}</td>
                            <td>${activeLabel}</td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-primary me-1" onclick="editUser(${u.userId})" title="Edit"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger me-1" onclick="deleteUser(${u.userId})" title="Deactivate"><i class="bi bi-person-x"></i></button>
                                <button class="btn btn-sm btn-outline-success" onclick="initBalance(${u.userId})" title="Initialize Leave Balances"><i class="bi bi-wallet2"></i></button>
                            </td>
                        </tr>
                    `;
                });
                $('#userTableBody').html(html);
            });
        }

        function clearForm() {
            $('#userId').val('');
            $('#firstName').val('');
            $('#lastName').val('');
            $('#userEmail').val('');
            $('#userPassword').val('');
            $('#userRole').val('1');
            $('#isActive').prop('checked', true);
            $('#passwordGroup').show();
            $('#activeGroup').attr('style', 'display:none !important;');
        }

        function editUser(id) {
            apiCall('/Users/' + id, 'GET', null, function(u) {
                $('#userId').val(u.userId);
                $('#firstName').val(u.firstName);
                $('#lastName').val(u.lastName);
                $('#userEmail').val(u.email);
                $('#userRole').val(u.role === 'Admin' || u.role === 0 ? '0' : '1');
                $('#isActive').prop('checked', u.isActive);
                $('#passwordGroup').hide();
                $('#activeGroup').attr('style', 'display:block !important;');
                new bootstrap.Modal(document.getElementById('userModal')).show();
            });
        }

        function saveUser() {
            const id = $('#userId').val();
            if (!id) {
                const data = {
                    firstName: $('#firstName').val(),
                    lastName: $('#lastName').val(),
                    email: $('#userEmail').val(),
                    password: $('#userPassword').val(),
                    role: parseInt($('#userRole').val())
                };
                apiCall('/Users', 'POST', data, function() {
                    $('#userModal').modal('hide');
                    loadUsers();
                });
            } else {
                const data = {
                    firstName: $('#firstName').val(),
                    lastName: $('#lastName').val(),
                    email: $('#userEmail').val(),
                    role: parseInt($('#userRole').val()),
                    isActive: $('#isActive').is(':checked')
                };
                apiCall('/Users/' + id, 'PUT', data, function() {
                    $('#userModal').modal('hide');
                    loadUsers();
                });
            }
        }

        function deleteUser(id) {
            if(confirm('Are you sure you want to deactivate this user?')) {
                apiCall('/Users/' + id, 'DELETE', null, function() {
                    loadUsers();
                });
            }
        }

        function initBalance(userId) {
            const year = new Date().getFullYear();
            apiCall(`/LeaveBalances/initialize/${userId}/${year}`, 'POST', null, function() {
                alert('Leave balances initialized successfully!');
            });
        }
    </script>
}
